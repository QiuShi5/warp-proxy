# Published image used by docker-compose.yml and docker-compose.cluster.yml.
WARP_PROXY_IMAGE=ghcr.io/qiushi5/warp-proxy:latest

# Strongly recommended if any proxy port is exposed beyond localhost.
PROXY_USER=warp_proxy
PROXY_PASS=change_this_password

# Web management UI and API login.
WEB_USER=admin
WEB_PASS=change_this_web_password
WEB_SESSION_SECRET=change_this_session_secret
# Set to 1 only when the panel is served over HTTPS.
WEB_COOKIE_SECURE=0

# Same behavior as the original project: reconnect WARP every N minutes.
# Set to 0 to disable.
REFRESH_INTERVAL=30
